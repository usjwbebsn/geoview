# ─────────────────────────────────────────────────────────────────────
# GeoView — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEXT_PUBLIC_* vars are safe for the browser.
# Others are server-only — NEVER expose to the client.
# ─────────────────────────────────────────────────────────────────────

# ── Sentinel Hub ──────────────────────────────────────────────────────
# Your Sentinel Hub instance ID (from Dashboard → Configuration Utility)
# Required for WMS satellite layer to work.
NEXT_PUBLIC_SH_INSTANCE_ID=YOUR_INSTANCE_ID

# ── Copernicus Data Space Ecosystem (CDSE) ───────────────────────────
# OAuth2 credentials for the /api/auth/token proxy route.
# Register at: https://identity.dataspace.copernicus.eu
NEXT_PUBLIC_CDSE_CLIENT_ID=cdse-public
CDSE_CLIENT_SECRET=

# API base URLs (defaults are the public CDSE endpoints)
NEXT_PUBLIC_CDSE_AUTH_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
NEXT_PUBLIC_CDSE_PROCESS_API=https://sh.dataspace.copernicus.eu/api/v1/process
NEXT_PUBLIC_CDSE_CATALOG_API=https://catalogue.dataspace.copernicus.eu/stac
NEXT_PUBLIC_CDSE_WMS_URL=https://sh.dataspace.copernicus.eu/ogc/wms

# ── Geocoding ────────────────────────────────────────────────────────
# Nominatim is free and public; no key needed.
# Override only if you run a private Nominatim instance.
NEXT_PUBLIC_NOMINATIM_URL=https://nominatim.openstreetmap.org
